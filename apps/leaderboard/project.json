{
  "name": "leaderboard",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/leaderboard/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm astro build",
        "cwd": "apps/leaderboard"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm astro dev",
        "cwd": "apps/leaderboard"
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "leaderboard:build",
        "port": 4300,
        "staticFilePath": "dist/apps/leaderboard"
      }
    },
    "serve-pwa": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run leaderboard:serve-static"
      }
    }
  }
}
